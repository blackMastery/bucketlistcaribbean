# Supabase — copy to .env.local and fill with your project's values
# Use the same Supabase project as mista-concierge-travel-design (shared data).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Required for transactional emails.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL — local dev only (localhost). Production uses https://www.bucketlistcaribbean.com
# from the site registry; do NOT set this to the Mista domain on Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Required on Vercel — must be "bucketlist" for this deployment.
SITE_ID=bucketlist

# Cross-site cache busting when Mista admin edits this site's content or catalog.
REVALIDATION_SECRET=change-me-in-production

# Mista admin dashboard URL (booking notification emails link here).
MISTA_ADMIN_URL=http://localhost:3000

# Resend — transactional emails (optional)
RESEND_API_KEY=re_xxxxxxxx
BOOKING_FROM_EMAIL=Bucketlist Vacation <bookings@yourdomain.com>
EMAIL_REPLY_TO=
BOOKING_ADMIN_EMAIL=hello@mistatravel.com

# Chatbot LLM (optional)
OPENAI_API_KEY=sk-xxxxxxxx
